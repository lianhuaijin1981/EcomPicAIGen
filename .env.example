# ══════════════════════════════════════════════════════════════════════
# EcomPicAIGen 环境变量配置
# ══════════════════════════════════════════════════════════════════════
# 复制此文件为 .env 后填入实际值

# ── 应用配置 ─────────────────────────────────────────────────────
APP_ID=ecompicaigen
APP_SECRET=                # 应用密钥（用于 JWT 签发，请使用强随机字符串）
PORT=3000
NODE_ENV=development       # development | production

# 生产环境必须填写以下字段
# ALLOWED_ORIGIN=https://your-domain.com

# ── 数据库 ───────────────────────────────────────────────────────
# MySQL 生产配置
# DATABASE_URL=mysql://user:password@localhost:3306/ecompicaigen

# SQLite 开发配置（默认，无需配置）
DATABASE_URL=file:./dev.db

# ── JWT ─────────────────────────────────────────────────────────
# 生产环境必须更换为强随机密钥（建议 64+ 字符）
JWT_SECRET=dev-secret-change-in-prod

# ── AI API ───────────────────────────────────────────────────────
# FLUX.1-dev via Replicate（生产环境接入真实 AI 时填写）
FLUX_API_KEY=
FLUX_API_ENDPOINT=https://api.replicate.com/v1/predictions

# 通义万相 API（备用）
ZIMAGE_API_KEY=
ZIMAGE_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis

# ── 存储 ────────────────────────────────────────────────────────
# 生成图片存储目录
OUTPUT_DIR=./output/images

# ── 速率限制 ────────────────────────────────────────────────────
# 每分钟最大请求数（生产环境建议 30）
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
